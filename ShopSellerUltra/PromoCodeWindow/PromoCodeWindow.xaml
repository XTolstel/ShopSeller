<Window x:Class="AutoSellerUltra.PromoCodeWindow.PromoCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Promo Code"
        Height="260"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,12"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Text="Promo code name: SPRING-SALE"/>

        <TextBlock Grid.Row="1"
                   Margin="0,0,0,12"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Text="Discount: 15%"/>

        <TextBlock Grid.Row="2"
                   Margin="0,0,0,12"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Text="Expiration date: 2026-12-31"/>

        <TextBlock Grid.Row="3"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Text="Developer password: dev-password-123"/>
    </Grid>
</Window>
