<Window x:Class="AutoSellerUltra.PromoCodeWindow.PromoCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Promo Code"
        Height="290"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Promo code name" Margin="0,0,0,4"/>
            <TextBox Height="30" Text=""/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Discount" Margin="0,0,0,4"/>
            <TextBox Height="30" Text=""/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Expiration date" Margin="0,0,0,4"/>
            <DatePicker Height="30" SelectedDate=""/>
        </StackPanel>

        <StackPanel Grid.Row="3">
            <TextBlock Text="Developer password" Margin="0,0,0,4"/>
            <TextBox Height="30" Text=""/>
        </StackPanel>
    </Grid>
</Window>
