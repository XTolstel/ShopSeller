<Window x:Class="AutoSellerUltra.PromoCodeWindow.PromoCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Promo Code"
        Height="430"
        Width="560"
        MinHeight="430"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Promo code name" Margin="0,0,0,6"/>
            <TextBox x:Name="PromoCodeTextBox" Height="32"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="Discount" Margin="0,0,0,6"/>
            <TextBox x:Name="DiscountTextBox" Height="32"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="Expiration date" Margin="0,0,0,6"/>
            <Grid Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="DayTextBox" Grid.Column="0" Height="32" VerticalContentAlignment="Center"/>

                <ComboBox x:Name="MonthComboBox" Grid.Column="2" Height="32" SelectedIndex="0">
                    <ComboBoxItem Content="January"/>
                    <ComboBoxItem Content="February"/>
                    <ComboBoxItem Content="March"/>
                    <ComboBoxItem Content="April"/>
                    <ComboBoxItem Content="May"/>
                    <ComboBoxItem Content="June"/>
                    <ComboBoxItem Content="July"/>
                    <ComboBoxItem Content="August"/>
                    <ComboBoxItem Content="September"/>
                    <ComboBoxItem Content="October"/>
                    <ComboBoxItem Content="November"/>
                    <ComboBoxItem Content="December"/>
                </ComboBox>

                <ComboBox x:Name="YearComboBox" Grid.Column="4" Height="32" SelectedIndex="0">
                    <ComboBoxItem Content="2026"/>
                    <ComboBoxItem Content="2027"/>
                    <ComboBoxItem Content="2028"/>
                    <ComboBoxItem Content="2029"/>
                    <ComboBoxItem Content="2030"/>
                    <ComboBoxItem Content="2031"/>
                    <ComboBoxItem Content="2032"/>
                    <ComboBoxItem Content="2033"/>
                    <ComboBoxItem Content="2034"/>
                    <ComboBoxItem Content="2035"/>
                </ComboBox>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="Developer password" Margin="0,0,0,6"/>
            <PasswordBox x:Name="DeveloperPasswordBox" Height="32"/>
        </StackPanel>

        <Button Grid.Row="4"
                Content="OK"
                Height="34"
                Width="120"
                HorizontalAlignment="Right"
                Click="OkButton_Click"/>
    </Grid>
</Window>
