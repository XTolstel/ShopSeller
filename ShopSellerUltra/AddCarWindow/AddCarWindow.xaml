<Window x:Class="AutoSellerUltra.AddCarWindow.AddCarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add car"
        Width="520"
        Height="520"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Name -->
        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Name:"/>
        <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Margin="8,0,0,8"/>

        <!-- Category -->
        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Category:"/>
        <TextBox x:Name="CategoryTextBox" Grid.Row="1" Grid.Column="1" Margin="8,0,0,8"/>

        <!-- Price -->
        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Price:"/>
        <TextBox x:Name="PriceTextBox" Grid.Row="2" Grid.Column="1" Margin="8,0,0,8"/>

        <!-- Quantity -->
        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Quantity:"/>
        <TextBox x:Name="QuantityTextBox" Grid.Row="3" Grid.Column="1" Margin="8,0,0,8"/>

        <!-- Image picker -->
        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Image:"/>

        <TextBox x:Name="ImagePathTextBox"
                 Grid.Row="4" Grid.Column="1"
                 Margin="8,0,0,8"
                 IsReadOnly="True"/>

        <Button Grid.Row="4" Grid.Column="2"
                Margin="8,0,0,8"
                Padding="10,4"
                Content="Browse..."
                Click="BrowseImageButton_Click"/>

        <!-- Preview -->
        <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3"
                BorderBrush="#B0B0B0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8"
                Margin="0,8,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Preview"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <Viewbox Grid.Row="1" Stretch="Uniform">
                    <Image x:Name="PreviewImage"
                           Width="420"
                           Height="240"
                           Stretch="Uniform"/>
                </Viewbox>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button Content="Add"
                    Width="90"
                    Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
