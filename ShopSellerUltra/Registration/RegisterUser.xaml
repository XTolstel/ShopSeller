<Window x:Class="AutoSellerUltra.Registration.RegisterUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register"
        Width="350"
        Height="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border Padding="20"
            CornerRadius="10"
            BorderBrush="#DDD"
            BorderThickness="1"
            Background="White">

        <StackPanel>

            <TextBlock Text="Registration"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Login -->
            <Grid Margin="0,0,0,12">
                <TextBox x:Name="LoginTextBox"
                         Height="28"
                         VerticalContentAlignment="Center"/>
                <TextBlock Text="Login"
                           Foreground="Gray"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=LoginTextBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Email -->
            <Grid Margin="0,0,0,12">
                <TextBox x:Name="EmailTextBox"
                         Height="28"
                         VerticalContentAlignment="Center"/>
                <TextBlock Text="Email"
                           Foreground="Gray"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=EmailTextBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Password -->
            <Grid Margin="0,0,0,12">
                <PasswordBox x:Name="PasswordBox"
                 Height="28"
                 PasswordChanged="PasswordBox_PasswordChanged"/>

                <TextBlock x:Name="PasswordWatermark"
               Text="Password"
               Foreground="Gray"
               Margin="6,0,0,0"
               VerticalAlignment="Center"
               IsHitTestVisible="False"/>
            </Grid>


            <!-- Birth date -->
            <Grid Margin="0,0,0,20">
                <TextBox x:Name="BirthDateTextBox"
                         Height="28"
                         VerticalContentAlignment="Center"/>
                <TextBlock Text="DD.MM.YYYY"
                           Foreground="Gray"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=BirthDateTextBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Button Content="Register"
                    Height="32"
                    FontWeight="Bold"
                    Background="#007BFF"
                    Foreground="White"
                    Click="RegisterButton_Click"/>

        </StackPanel>
    </Border>
</Window>
